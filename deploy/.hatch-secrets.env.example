# Tank Hatchery secrets — copy to deploy/.hatch-secrets.env (gitignored) and fill.
# All values live in the fleet lockbox (sneakyfree/kit-army-config/ACCESS_LOCKBOX.md).
# hatch-tank.sh sources this file before running.

# --- Cloudflare (all zones live in one account) ---
export CF_ACCOUNT_ID=193b347aedeaafe35de0b5a534b2d9aa
export CF_GOD_TOKEN=            # cfut_… — Zone:Read + zone.create + Pages (lockbox §16 god token)
export CF_DNS_TOKEN=           # cfat_… — Zone:Read + DNS:Edit across all zones
export CF_PAGES_TOKEN=         # cfut_… — Pages/Workers Edit + custom-domain attach

# --- Resend (one account, per-domain verified senders) ---
export RESEND_API_KEY=         # re_… — the shared ecosystem key (YOLOTOKEN)

# --- Stalwart mail server (shared multi-tenant, on the windy-mail EC2) ---
export STALWART_PASSWORD=      # admin secret (STALWART_ADMIN_SECRET on the container)
# The ONE founder mailbox every tank's office@ address consolidates into (Grant
# reads all domains under this single Roundcube login). Defaults shown.
export STALWART_FOUNDER_ACCOUNT=c3
export STALWART_FOUNDER_EMAIL=gwhitmer@windstorminstitute.org
export STALWART_FOUNDER_PASSWORD=   # founder mailbox password (for the smoke mail check)
# Optional overrides (defaults shown):
# export STALWART_USER=admin
# export STALWART_MGMT_URL=http://localhost:8080
# export HATCH_MAIL_SSH=windy-mail
# export HATCH_MAIL_HOST=mail.windymail.ai

# --- VPS (backend host) ---
# export HATCH_VPS_SSH=vps
# export HATCH_VPS_IP=72.60.118.54
# export HATCH_VPS_REPO=/root/wagyutank

# Extraction/AI lane for tank.env (optional — defaults to the Veron 5090 local
# model over WireGuard; the Groq free tier's 100k tokens/DAY cannot feed nightly
# crawl ingests). Any OpenAI-compatible endpoint works.
#TANK_AI_BASE_URL=http://10.10.0.6:11434/v1
#TANK_AI_MODEL=qwen2.5:7b-instruct

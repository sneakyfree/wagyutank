# Dev defaults. Copy to .env and adjust.
DATABASE_URL=sqlite:///./wagyutank.db
# Production example:
# DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/wagyutank

JWT_SECRET=dev-secret-change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# CORS (frontend origin)
FRONTEND_ORIGIN=http://localhost:3000

# Stripe (creds live in the kit-army-config lockbox — do not commit real keys)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
PLATFORM_FEE_BPS=0        # platform take-rate in basis points; 0 = free at launch

# ---- AI providers (swappable) ----
# AI_PROVIDER: anthropic | openai | windymind. Empty key on the chosen provider => template fallback.
AI_PROVIDER=anthropic

# Anthropic — PRODUCT key (sk-ant-api03-… from console.anthropic.com), NOT the Max-plan OAuth token.
# Haiku on both jobs during testing so all Haiku spend is attributable to WagyuTank.
ANTHROPIC_API_KEY=
ANTHROPIC_VISION_MODEL=claude-haiku-4-5
ANTHROPIC_ADCOPY_MODEL=claude-haiku-4-5

# OpenAI-compatible (drop in an OpenAI key, or reuse this block for any compatible gateway)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_VISION_MODEL=gpt-4o-mini
OPENAI_ADCOPY_MODEL=gpt-4o-mini

# Windy Mind (free-compute gateway; OpenAI-compatible). Set base_url + key + models, then AI_PROVIDER=windymind.
WINDYMIND_API_KEY=
WINDYMIND_BASE_URL=
WINDYMIND_VISION_MODEL=
WINDYMIND_ADCOPY_MODEL=
